# ============================================================
# CONFIGURACIÓN DEL SISTEMA SIG TRANSPORTE
# Copia este archivo como .env y ajusta los valores
# ============================================================

# Flask
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=cambia_esta_clave_secreta_por_una_segura_2026

# Base de datos PostgreSQL
DATABASE_URL=postgresql://postgres:tu_password@localhost:5432/sig_transporte

# JWT
JWT_SECRET_KEY=cambia_este_jwt_secret_2026
JWT_ACCESS_TOKEN_EXPIRES=3600
JWT_REFRESH_TOKEN_EXPIRES=2592000

# Servidor
HOST=0.0.0.0
PORT=5000

# Carpeta para archivos generados (reportes Excel, QR images)
UPLOAD_FOLDER=./static/uploads
REPORTS_FOLDER=./static/reports
QR_FOLDER=./static/qr_codes

# Firebase Cloud Messaging (para notificaciones push a Flutter)
# Obtén esta clave desde Firebase Console de tu proyecto
FCM_SERVER_KEY=TU_FCM_SERVER_KEY_AQUI

# Tolerancia geográfica en metros para validar si el bus está en ruta
RADIO_TOLERANCIA_METROS=100
